# Base URL of the backend API. MUST include the /api suffix because the
# backend mounts every router under /api/. Examples:
#   - Local dev:  http://localhost:8000/api
#   - Production: https://api.okaction.example.com/api
VITE_API_URL=http://localhost:8000/api

# Base URL of the backend WebSocket endpoint. Same /api convention applies.
VITE_WS_URL=ws://localhost:8000/api
